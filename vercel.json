{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/beacon",  "destination": "/beacon-app" },
    { "source": "/beacon/", "destination": "/beacon-app" }
  ],
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 60
    },
    "api/beacon/**/*.js": {
      "memory": 256,
      "maxDuration": 60
    },
    "api/beacons/**/*.js": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/beacon/cron/daily", "schedule": "0 14 * * *" },
    { "path": "/api/beacon/cron/trial-emails", "schedule": "0 15 * * *" },
    { "path": "/api/beacon/cron/weekly", "schedule": "0 14 * * 1" },
    { "path": "/api/beacon/cron/monthly", "schedule": "0 14 1 * *" },
    { "path": "/api/beacon/cron/quarterly", "schedule": "0 14 1 1,4,7,10 *" },
    { "path": "/api/beacons/google/gmail-sync", "schedule": "0 */6 * * *" },
    { "path": "/api/beacons/google/drive-sync", "schedule": "30 */6 * * *" },
    { "path": "/api/site-review-request", "schedule": "0 16 * * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
